# dependencies
node_modules/
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production builds
/build
/dist
frontend/build

# environment variables (never commit secrets)
.env
.env.*
!.env.example

# logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# runtime / cache
.cache/
*.eslintcache
.parcel-cache/
.turbo/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# user uploads (generated at runtime)
uploads/*
!uploads/.gitkeep

# misc
http
